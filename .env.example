# ===================================
# إعدادات SAMIRMAX AI Studio
# ===================================

# إعدادات التطبيق الأساسية
APP_NAME="SAMIRMAX AI Studio"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY="your-secret-key-change-in-production"

# إعدادات قاعدة البيانات
DATABASE_URL="postgresql://samirmax_user:samirmax_password@localhost:5432/samirmax_ai"
REDIS_URL="redis://localhost:6379"

# مفاتيح API للذكاء الاصطناعي
# احصل على مفتاح OpenAI من: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# احصل على token Hugging Face من: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN="hf_your-huggingface-token-here"

# احصل على مفتاح Google من: https://console.cloud.google.com/
GOOGLE_API_KEY="your-google-api-key-here"

# إعدادات الملفات
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=104857600  # 100MB
ALLOWED_IMAGE_TYPES="jpg,jpeg,png,webp"
ALLOWED_VIDEO_TYPES="mp4,avi,mov,mkv"

# إعدادات معالجة الذكاء الاصطناعي
MAX_GENERATION_TIME=300  # 5 دقائق
DEFAULT_IMAGE_SIZE="1024x1024"
DEFAULT_VIDEO_DURATION=30  # ثانية

# إعدادات الأمان
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM="HS256"

# إعدادات CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000"

# إعدادات Celery
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# إعدادات البريد الإلكتروني (اختياري)
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="your-email@gmail.com"

# إعدادات التخزين السحابي (اختياري)
# AWS S3
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_BUCKET_NAME="samirmax-ai-storage"
AWS_REGION="us-east-1"

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT="your-project-id"
GOOGLE_CLOUD_BUCKET="samirmax-ai-storage"

# إعدادات المراقبة (اختياري)
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# إعدادات التحليلات (اختياري)
GOOGLE_ANALYTICS_ID="GA-XXXXX-X"
MIXPANEL_TOKEN="your-mixpanel-token"

# إعدادات الإنتاج
ENVIRONMENT="development"  # development, staging, production
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# إعدادات Docker
POSTGRES_DB="samirmax_ai"
POSTGRES_USER="samirmax_user"
POSTGRES_PASSWORD="samirmax_password"

# إعدادات الواجهة الأمامية
REACT_APP_API_URL="http://localhost:8000"
REACT_APP_VERSION="1.0.0"
REACT_APP_ENVIRONMENT="development"

# ===================================
# ملاحظات مهمة:
# ===================================
# 1. انسخ هذا الملف إلى .env وغيّر القيم حسب بيئتك
# 2. لا تشارك ملف .env مع أي شخص أو تحفظه في نظام التحكم بالإصدارات
# 3. استخدم كلمات مرور قوية ومفاتيح آمنة
# 4. للإنتاج، استخدم خدمات إدارة المفاتيح مثل AWS Secrets Manager
# 5. تأكد من تفعيل HTTPS في الإنتاج